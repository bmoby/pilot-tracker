# Подключение локального приложения к онлайн-проекту Supabase.
# Публичные значения используются для входа администратора через Supabase Auth.
# Локальный Supabase через Docker для этого окружения не используется.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Секретный ключ нужен только серверным скриптам обслуживания данных.
# Не используйте префикс NEXT_PUBLIC для секретного ключа.
PILOT_SUPABASE_URL=
PILOT_SUPABASE_SERVICE_ROLE_KEY=
